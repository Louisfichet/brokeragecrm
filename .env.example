# ===========================================
# CRM Brokerage — Variables d'environnement
# ===========================================

# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/crm_brokerage?schema=public"

# Auth — JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-too-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Auth — Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# NextAuth
NEXTAUTH_SECRET="change-me-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# API
API_URL="http://localhost:3001"
API_PORT=3001

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Docuseal (Phase 2)
DOCUSEAL_URL=""
DOCUSEAL_API_KEY=""

# Fichiers uploads
UPLOAD_DIR="/uploads"
MAX_FILE_SIZE_MB=50
